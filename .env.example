VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Pins the extension ID so it never changes between unpacked reloads.
# Generate: chrome://extensions → Pack Extension → select .output/chrome-mv3/
# Open the generated .pem file, copy everything BETWEEN (not including) the
# -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- lines, then
# paste it as a single line below (remove any line breaks).
VITE_EXTENSION_KEY=
